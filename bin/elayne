#!/usr/bin/env php
<?php

// Support both standalone use and installation as a Composer dependency
$autoloaders = [
    __DIR__ . '/../vendor/autoload.php',      // standalone
    __DIR__ . '/../../../../autoload.php',     // installed as vendor/imagewize/elayne-cli
];

$loaded = false;
foreach ($autoloaders as $autoloader) {
    if (file_exists($autoloader)) {
        require $autoloader;
        $loaded = true;
        break;
    }
}

if (!$loaded) {
    fwrite(STDERR, "Autoloader not found. Run 'composer install' in the elayne-cli directory or the theme root.\n");
    exit(1);
}

use Imagewize\ElaynePatternCli\Application;

$application = new Application();
$application->run();
